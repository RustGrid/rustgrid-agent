{
  "heartbeat_interval_seconds": 15,
  "max_concurrency": 4,
  "executor": {
    "kind": "docker_sandbox",
    "command": "sbx",
    "template": "docker.io/docker/sandbox-templates@sha256:943c52aa48a4f4473a9c91e43aced8def51667935ad9866ffc29a821d5982f97",
    "cpus": 4,
    "memory": "8g",
    "capacity_cpus": 16,
    "capacity_memory": "32g"
  },
  "lease_seconds": 900,
  "workspace_root": null,
  "command_timeout_seconds": 1800,
  "run_timeout_seconds": 7200,
  "failed_workspace_retention_hours": 72,
  "max_command_output_bytes": 8388608,
  "max_workspace_bytes": 5368709120,
  "max_child_memory_bytes": 8589934592,
  "max_child_file_bytes": 1073741824,
  "max_child_open_files": 1024
}
